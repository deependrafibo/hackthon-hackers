{
  "name": "hackthon-hackers",
  "version": "1.0.0",
  "description": "Multi-site Playwright test automation framework",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "playwright test",
    "clean:results": "node scripts/clean-test-results.mjs",
    "test:priority": "node scripts/run-priority-tests.mjs",
    "test:priority:public": "SKIP_AUTH_SETUP=true node scripts/run-priority-tests.mjs",
    "test:priority:blockpeer": "node scripts/run-priority-tests.mjs --sites=blockpeer",
    "test:priority:blockpeer:high": "node scripts/run-priority-tests.mjs --sites=blockpeer --priorities=high --run-id=run-blockpeer-high",
    "test:priority:blockpeer:medium": "node scripts/run-priority-tests.mjs --sites=blockpeer --priorities=medium --run-id=run-blockpeer-medium",
    "test:priority:blockpeer:low": "node scripts/run-priority-tests.mjs --sites=blockpeer --priorities=low --run-id=run-blockpeer-low",
    "test:priority:crickbox": "node scripts/run-priority-tests.mjs --sites=crickbox",
    "test:report": "node scripts/export-test-report.mjs",
    "test:show": "npx playwright show-report test-results/$(ls -t test-results | head -1)/html-report",
    "server": "npx tsx server/index.ts",
    "server:dev": "npx tsx watch server/index.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0-alpha-1775584683000",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "minimist": "^1.2.5",
    "playwright": "1.60.0-alpha-1775584683000"
  }
}
