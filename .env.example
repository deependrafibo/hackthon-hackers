# ─── Dynamic Site Configuration ──────────────────────────────────────────────
# Add any website by following this naming convention:
#
#   <SITENAME>_BASE_URL   = https://...              (required)
#   <SITENAME>_EMAIL      = your-email@example.com   (required for auth tests)
#   <SITENAME>_PASSWORD   = your-password            (required for auth tests)
#   <SITENAME>_AUTH_ROUTE = /auth/signin             (optional, default: /auth/signin)
#
# The framework auto-discovers all *_BASE_URL entries and creates:
#   - A test project per site
#   - A results folder per site (with passed.json, failed.json, full_result.json)
#   - A screenshots folder per site
#
# To add a new site, just add its credentials below — no code changes needed.
# ─────────────────────────────────────────────────────────────────────────────

BLOCKPEER_BASE_URL=https://staging-react.blockpeer.finance
BLOCKPEER_EMAIL=your-blockpeer-email@example.com
BLOCKPEER_PASSWORD=your-blockpeer-password

CRICKBOX_BASE_URL=https://crick-box07.vercel.app
CRICKBOX_EMAIL=your-crickbox-email@example.com
CRICKBOX_PASSWORD=your-crickbox-password

# ─── Example: adding a third site ───────────────────────────────────────────
# SPEAKSPORT_BASE_URL=https://staging.speaksport.ai
# SPEAKSPORT_EMAIL=your-email@example.com
# SPEAKSPORT_PASSWORD=your-password
# SPEAKSPORT_AUTH_ROUTE=/auth/login

# ─── Optional fallback values ───────────────────────────────────────────────
# These are used as fallback email/password when a site-specific one is missing
TEST_EMAIL=
TEST_PASSWORD=
